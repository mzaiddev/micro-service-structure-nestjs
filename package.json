{
  "name": "micro-service-structure-nestjs",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade NestJS microservices monorepo with API gateway, shared libraries, and scalable service patterns.",
  "license": "MIT",
  "scripts": {
    "start": "nest start api-gateway",
    "start:dev": "nest start api-gateway --watch",
    "start:dev:gateway": "nest start api-gateway --watch",
    "start:dev:auth": "nest start auth-service --watch",
    "start:dev:user": "nest start user-service --watch",
    "start:dev:product": "nest start product-service --watch",
    "start:dev:order": "nest start order-service --watch",
    "start:dev:notification": "nest start notification-service --watch",
    "build": "nest build",
    "build:gateway": "nest build api-gateway",
    "build:auth": "nest build auth-service",
    "build:user": "nest build user-service",
    "build:product": "nest build product-service",
    "build:order": "nest build order-service",
    "build:notification": "nest build notification-service",
    "build:all": "npm run build:gateway && npm run build:auth && npm run build:user && npm run build:product && npm run build:order && npm run build:notification",
    "lint": "eslint \"{apps,libs}/**/*.ts\"",
    "format": "prettier --write \"{apps,libs}/**/*.{ts,js,json,md,yml,yaml}\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "service:scaffold": "node tools/scaffold-service.mjs"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/microservices": "^11.1.0",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "amqplib": "^0.10.8",
    "bcryptjs": "^3.0.2",
    "cache-manager": "^6.4.3",
    "cache-manager-ioredis-yet": "^2.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "joi": "^17.13.3",
    "mongoose": "^8.19.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.27",
    "uuid": "^11.1.0",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.3",
    "@nestjs/testing": "^11.1.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
